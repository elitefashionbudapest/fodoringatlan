# Prevent directory listing
Options -Indexes

# Block direct browser access to PHP files (must go through proper routing)
# API files return JSON only — no HTML output expected from direct access
# But we DO allow direct PHP access since that's how the API works

# Additional security headers for API responses
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Cache-Control "no-store, no-cache, must-revalidate"
    Header always unset X-Powered-By
</IfModule>

# Block access to internal files
<FilesMatch "^(config|db|cors|auth|audit)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
